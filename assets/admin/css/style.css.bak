/* assets/css/style.css */
/* Modern Luxurious Sage-Green & Gold Design System */

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap');

:root {
    /* Color Palette */
    --primary: #3d2e23;          /* Dark Brown */
    --primary-light: #524032;    /* Lighter Brown */
    --primary-dark: #241a13;     /* Deep Brown */
    --accent: #d39673;           /* Soft Terracotta / Warm accent */
    --accent-light: #e5ad8c;     /* Lighter Accent */
    --accent-hover: #b57a58;     /* Darker Accent */
    --bg-light: #f3ebe1;         /* Beige / Cream Background */
    --bg-dark: #3d2e23;          /* Dark Background for Footer/Sidebar */
    --bg-card: #ffffff;          /* White for Cards */
    --text-dark: #222524;        /* Dark Charcoal */
    --text-light: #ffffff;       /* Pure White */
    --text-muted: #6e7572;       /* Muted gray */
    --border-color: #e6dfd5;     /* Light beige border */
    
    /* Semantic Colors */
    --success: #2e7d32;
    --success-bg: #e8f5e9;
    --warning: #f57c00;
    --warning-bg: #fff3e0;
    --danger: #d32f2f;
    --danger-bg: #ffebee;
    --info: #0288d1;
    --info-bg: #e1f5fe;
    
    /* Layout & Effects */
    --font-heading: 'Outfit', sans-serif;
    --font-body: 'Inter', sans-serif;
    --radius-sm: 8px;
    --radius-md: 14px;
    --radius-lg: 24px;
    --shadow-sm: 0 4px 6px -1px rgba(27, 53, 47, 0.05), 0 2px 4px -1px rgba(27, 53, 47, 0.03);
    --shadow-md: 0 10px 15px -3px rgba(27, 53, 47, 0.08), 0 4px 6px -2px rgba(27, 53, 47, 0.05);
    --shadow-lg: 0 20px 25px -5px rgba(27, 53, 47, 0.12), 0 10px 10px -5px rgba(27, 53, 47, 0.04);
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Reset Base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: var(--font-body);
    background-color: var(--bg-light);
    color: var(--text-dark);
    font-size: 14px;
    line-height: 1.6;
    overflow-x: hidden;
}

h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    color: var(--primary);
    font-weight: 600;
    line-height: 1.3;
}

a {
    color: var(--accent-hover);
    text-decoration: none;
    transition: var(--transition);
}

a:hover {
    color: var(--primary);
}

/* ----------------------------------
   1. GLASSMORPHISM LOGIN PAGE
   ---------------------------------- */
.login-body {
    background: linear-gradient(rgba(61, 46, 35, 0.85), rgba(36, 26, 19, 0.96)), 
                url('../img/spa_login_bg.png') no-repeat center center / cover;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
}

.login-card {
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-lg);
    padding: 35px 30px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    text-align: center;
    animation: fadeIn 0.8s ease-out;
}

.login-logo {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 2px;
    margin-bottom: 5px;
    text-transform: uppercase;
}

.login-subtitle {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.85rem;
    margin-bottom: 20px;
    letter-spacing: 0.5px;
}

.form-group-glass {
    margin-bottom: 18px;
    text-align: left;
    position: relative;
}

.form-group-glass label {
    display: block;
    color: var(--accent-light);
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 8px;
    transition: var(--transition);
}

.form-control-glass {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    color: var(--text-light);
    font-family: var(--font-body);
    font-size: 0.9rem;
    transition: var(--transition);
}

.form-control-glass:focus {
    outline: none;
    border-color: var(--accent);
    background: rgba(255, 255, 255, 0.1);
    box-shadow: 0 0 15px rgba(191, 161, 95, 0.3);
}

.btn-glass {
    width: 100%;
    background: linear-gradient(135deg, var(--accent), #e2cf9f);
    color: var(--primary-dark);
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 10px;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    box-shadow: 0 10px 20px -10px rgba(191, 161, 95, 0.5);
    transition: var(--transition);
    margin-top: 10px;
}

.btn-glass:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 25px -10px rgba(191, 161, 95, 0.7);
    filter: brightness(1.05);
}

.btn-glass:active {
    transform: translateY(0);
}

.error-alert {
    background: rgba(211, 47, 47, 0.15);
    border: 1px solid var(--danger);
    color: #ff8a80;
    padding: 12px;
    border-radius: var(--radius-sm);
    margin-bottom: 25px;
    font-size: 0.9rem;
    animation: shake 0.5s ease-in-out;
}

/* ----------------------------------
   2. MAIN DASHBOARD LAYOUT
   ---------------------------------- */
.wrapper {
    display: flex;
    min-height: 100vh;
}

/* Sidebar Styling */
.sidebar {
    width: 240px;
    background-color: var(--primary);
    color: var(--text-light);
    display: flex;
    flex-direction: column;
    position: fixed;
    height: 100vh;
    left: 0;
    top: 0;
    z-index: 100;
    box-shadow: var(--shadow-lg);
    transition: var(--transition);
}

.sidebar-brand {
    padding: 20px 25px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    gap: 15px;
}

.sidebar-logo-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    font-weight: 800;
    font-size: 1.4rem;
}

.sidebar-brand-text {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 1px;
}

.sidebar-menu {
    list-style: none;
    padding: 15px 10px;
    flex: 1;
    overflow-y: auto;
}

.sidebar-menu li {
    margin-bottom: 8px;
}

.sidebar-menu a {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 10px 15px;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-heading);
    font-weight: 500;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    transition: var(--transition);
}

.sidebar-menu a i {
    width: 20px;
    text-align: center;
    font-size: 1.1rem;
}

.sidebar-menu a:hover {
    color: var(--accent);
    background: rgba(255, 255, 255, 0.04);
}

.sidebar-menu li.active a {
    color: var(--primary-dark);
    background: linear-gradient(135deg, var(--accent), #e2cf9f);
    font-weight: 600;
    box-shadow: 0 4px 12px rgba(191, 161, 95, 0.2);
}

.sidebar-footer {
    padding: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.sidebar-user {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 15px;
}

.sidebar-user-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background-color: var(--primary-light);
    color: var(--accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
}

.sidebar-user-info h5 {
    color: var(--text-light);
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 170px;
}

.sidebar-user-info span {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.75rem;
}

.btn-logout {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 10px;
    background: rgba(211, 47, 47, 0.1);
    color: #ff8a80;
    border: 1px solid rgba(211, 47, 47, 0.2);
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: var(--transition);
}

.btn-logout:hover {
    background: var(--danger);
    color: var(--text-light);
    border-color: var(--danger);
}

/* Main Content Area */
.main-content {
    margin-left: 240px;
    width: calc(100% - 240px);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    transition: var(--transition);
}

/* Top Navbar */
.top-navbar {
    height: 60px;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border-color);
    padding: 0 25px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 90;
    box-shadow: var(--shadow-sm);
}

.navbar-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.5px;
}

.navbar-date {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-muted);
    font-size: 0.85rem;
    background: var(--bg-light);
    padding: 6px 12px;
    border-radius: 30px;
    border: 1px solid var(--border-color);
}

.navbar-date i {
    color: var(--accent);
}

/* Container Wrapper */
.content-body {
    padding: 25px;
    flex: 1;
    animation: fadeIn 0.4s ease-in-out;
}

/* ----------------------------------
   3. SYSTEM WIDGETS & CARDS
   ---------------------------------- */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 25px;
}

.stats-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 18px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
}

.stats-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent-light);
}

.stats-info span {
    display: block;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 5px;
}

.stats-info h2 {
    font-size: 1.45rem;
    font-weight: 800;
}

.stats-icon {
    width: 54px;
    height: 54px;
    border-radius: var(--radius-sm);
    background-color: var(--bg-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 1.5rem;
    transition: var(--transition);
}

.stats-card:hover .stats-icon {
    background-color: var(--primary);
    color: var(--accent);
}

/* Content Panel */
.panel {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    margin-bottom: 25px;
    overflow: hidden;
}

.panel-header {
    padding: 15px 20px;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 15px;
}

.panel-title {
    font-size: 1.1rem;
    font-weight: 700;
    position: relative;
    padding-left: 15px;
}

.panel-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 3px;
    bottom: 3px;
    width: 4px;
    background: var(--accent);
    border-radius: 2px;
}

.panel-body {
    padding: 20px;
}

.admin-section-tabs {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px;
    margin-bottom: 20px;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(61, 46, 35, 0.08);
    border-radius: 999px;
    box-shadow: var(--shadow-sm);
}

.admin-section-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 36px;
    padding: 0 14px;
    border-radius: 999px;
    color: var(--text-muted);
    font-family: var(--font-heading);
    font-size: 0.84rem;
    font-weight: 700;
    white-space: nowrap;
    transition: var(--transition);
}

.admin-section-tab:hover {
    color: var(--primary);
    background: rgba(61, 46, 35, 0.05);
}

.admin-section-tab.active {
    color: var(--primary-dark);
    background: linear-gradient(135deg, var(--accent), #e2cf9f);
    box-shadow: 0 8px 16px rgba(181, 122, 88, 0.16);
}

.admin-panel-hint {
    color: var(--text-muted);
    font-size: 0.82rem;
    font-weight: 500;
}

.inline-payment-verification {
    margin-top: 16px;
    padding: 14px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: var(--bg-light);
    display: grid;
    gap: 10px;
}

.inline-payment-verification-title {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--primary);
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
}

.inline-payment-note {
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    font-size: 0.82rem;
}

.inline-payment-verification label {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-dark);
    font-size: 0.86rem;
    font-weight: 600;
    cursor: pointer;
}

.inline-payment-verification input[type="radio"] {
    accent-color: var(--accent-hover);
}

.admin-payment-summary {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 24px;
    align-items: start;
}

.admin-payment-label {
    display: block;
    margin-bottom: 2px;
    color: var(--primary);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.admin-payment-proof {
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    box-shadow: none;
}

.admin-payment-proof-frame {
    width: 100%;
    height: 160px;
    border-radius: var(--radius-sm);
    background: var(--bg-light);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    transition: all 0.2s ease;
}

.admin-payment-proof-frame:hover {
    border-color: var(--accent);
}

.admin-payment-proof-frame img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    cursor: pointer;
}

.admin-payment-proof-frame i {
    color: var(--text-muted);
    font-size: 2.2rem;
}

.admin-payment-content {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.admin-payment-facts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    border-bottom: 0;
}

.admin-payment-fact {
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
    margin-bottom: 0;
    min-height: auto;
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: none;
}

.admin-payment-fact:hover {
    background: transparent;
    border-color: transparent;
}

.admin-payment-fact span {
    display: block;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0;
}

.admin-payment-fact strong {
    color: var(--text-dark);
    font-size: 0.95rem;
    font-weight: 700;
    word-break: break-word;
}

.admin-payment-verification {
    margin-top: 4px;
    padding: 16px 0 0;
    border: 0;
    border-radius: 0;
    border-top: 1px solid var(--border-color);
    background: transparent;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.admin-payment-verification .inline-payment-verification-title {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--primary);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 800;
}

.admin-payment-verification .inline-payment-note {
    padding: 0;
    background: transparent;
    border: none;
    color: #d97706;
    font-size: 0.8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
}

.verification-options-group {
    display: flex;
    gap: 20px;
    margin-bottom: 2px;
}

.verification-option-card {
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-muted);
    transition: color 0.2s ease;
    margin: 0;
}

.verification-option-card:hover {
    color: var(--primary);
}

.verification-option-card input[type="radio"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
    margin: 0;
    accent-color: var(--accent-hover);
}

.admin-payment-verification .btn-spa {
    align-self: flex-start;
    min-width: 120px;
    justify-content: center;
    font-size: 0.85rem;
    padding: 8px 16px;
    height: 36px;
    margin-top: 4px;
    transition: all 0.2s ease;
}

.admin-payment-verification .btn-spa:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
}

@media (max-width: 1024px) {
    .admin-payment-summary {
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .admin-payment-proof {
        align-self: stretch;
    }

    .admin-payment-proof-frame {
        height: 180px;
    }
}

@media (max-width: 640px) {
    .admin-payment-facts {
        grid-template-columns: 1fr;
    }
    
    .verification-options-group {
        grid-template-columns: 1fr;
        gap: 8px;
    }
}

.settings-payment-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.75fr);
    gap: 24px;
    align-items: start;
}

.settings-subtitle {
    margin: 0 0 14px;
    color: var(--primary);
    font-size: 0.98rem;
    font-weight: 700;
}

.settings-payment-form {
    padding: 18px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    background: var(--bg-light);
}

@media (max-width: 991px) {
    .settings-payment-grid {
        grid-template-columns: 1fr;
    }
}

/* ----------------------------------
   4. TABLES AND DATA
   ---------------------------------- */
.table-responsive {
    width: 100%;
    overflow-x: auto;
}

.custom-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
}

.custom-table th {
    background-color: var(--bg-light);
    color: var(--primary);
    font-family: var(--font-heading);
    font-weight: 600;
    padding: 10px 15px;
    font-size: 0.9rem;
    border-bottom: 2px solid var(--border-color);
    letter-spacing: 0.5px;
}

.custom-table td {
    padding: 10px 15px;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-dark);
    font-size: 0.92rem;
    vertical-align: middle;
}

.custom-table tbody tr {
    transition: var(--transition);
}

.custom-table tbody tr:hover {
    background-color: rgba(191, 161, 95, 0.03);
}

/* Badges */
.badge {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 30px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: capitalize;
}

.badge-success {
    background-color: var(--success-bg);
    color: var(--success);
}

.badge-warning {
    background-color: var(--warning-bg);
    color: var(--warning);
}

.badge-danger {
    background-color: var(--danger-bg);
    color: var(--danger);
}

.badge-info {
    background-color: var(--info-bg);
    color: var(--info);
}

.badge-secondary {
    background-color: var(--border-color);
    color: var(--text-muted);
}

/* Action Buttons */
.btn-actions {
    display: flex;
    gap: 8px;
}

.btn-icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    color: var(--text-muted);
    background-color: var(--bg-card);
}

.btn-icon:hover {
    background-color: var(--primary);
    color: var(--accent);
    border-color: var(--primary);
}

.btn-icon-danger:hover {
    background-color: var(--danger);
    color: var(--text-light);
    border-color: var(--danger);
}

/* Standard Buttons */
.btn-spa {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    background-color: var(--primary);
    color: var(--accent);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    border: 1px solid var(--primary);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: var(--transition);
    box-shadow: var(--shadow-sm);
}

.btn-spa:hover {
    background-color: var(--primary-light);
    color: var(--accent-light);
    transform: translateY(-1px);
}

.btn-spa-accent {
    background: linear-gradient(135deg, var(--accent), #e2cf9f);
    color: var(--primary-dark);
    border: none;
}

.btn-spa-accent:hover {
    filter: brightness(1.08);
}

.btn-spa-outline {
    background-color: transparent;
    border-color: var(--border-color);
    color: var(--text-dark);
    box-shadow: none;
}

.btn-spa-outline:hover {
    background-color: var(--bg-light);
    border-color: var(--text-muted);
    color: var(--primary);
    transform: none;
}

/* ----------------------------------
   5. FORMS AND LAYOUTS
   ---------------------------------- */
.form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    margin-bottom: 30px;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--primary);
    margin-bottom: 8px;
}

.form-control {
    width: 100%;
    border: 1px solid var(--border-color);
    background-color: var(--bg-light);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    color: var(--text-dark);
    font-family: var(--font-body);
    font-size: 0.9rem;
    transition: var(--transition);
}

.form-control:focus {
    outline: none;
    border-color: var(--accent);
    background-color: var(--bg-card);
    box-shadow: 0 0 10px rgba(191, 161, 95, 0.15);
}

textarea.form-control {
    resize: vertical;
    min-height: 120px;
}

.form-actions {
    border-top: 1px solid var(--border-color);
    padding-top: 25px;
    display: flex;
    justify-content: flex-end;
    gap: 15px;
}

/* ----------------------------------
   6. VERIFIKASI PEMBAYARAN & MODALS
   ---------------------------------- */
.verifikasi-container {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
}

.bukti-box {
    background-color: var(--bg-light);
    border: 1px dashed var(--border-color);
    border-radius: var(--radius-md);
    padding: 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
}

.bukti-img {
    max-width: 100%;
    max-height: 550px;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-md);
    cursor: zoom-in;
    transition: var(--transition);
}

.bukti-img:hover {
    transform: scale(1.02);
}

.detail-pembayaran-list {
    list-style: none;
}

.detail-pembayaran-list li {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-color);
    font-size: 0.95rem;
}

.detail-pembayaran-list li strong {
    color: var(--primary);
}

.verifikasi-actions {
    margin-top: 30px;
    background: var(--bg-light);
    padding: 25px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
}

/* Modal Zoom */
.image-zoom-modal {
    display: none;
    position: fixed;
    z-index: 1000;
    padding-top: 50px;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    background-color: rgba(14, 31, 27, 0.95);
}

.zoom-content {
    margin: auto;
    display: block;
    max-width: 80%;
    max-height: 85%;
    border-radius: var(--radius-sm);
    box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
    animation: zoomIn 0.3s ease;
}

.zoom-close {
    position: absolute;
    top: 25px;
    right: 40px;
    color: #f1f1f1;
    font-size: 40px;
    font-weight: bold;
    cursor: pointer;
    transition: var(--transition);
}

.zoom-close:hover {
    color: var(--accent);
}

/* ----------------------------------
   7. POS & TRANSAKSI KASIR
   ---------------------------------- */
.pos-container {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 30px;
}

.pos-menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 20px;
}

.pos-item-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 20px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 160px;
    transition: var(--transition);
}

.pos-item-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    background-color: rgba(191, 161, 95, 0.02);
}

.pos-item-title {
    font-weight: 700;
    font-size: 1rem;
    color: var(--primary);
}

.pos-item-duration {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.pos-item-price {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--accent-hover);
    margin-top: 10px;
}

.cart-box {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 25px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    min-height: 480px;
}

.cart-header {
    border-bottom: 2px solid var(--border-color);
    padding-bottom: 15px;
    margin-bottom: 15px;
}

.cart-items {
    flex: 1;
    overflow-y: auto;
    max-height: 250px;
    margin-bottom: 20px;
}

.cart-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--bg-light);
}

.cart-item-info h5 {
    font-size: 0.9rem;
    font-weight: 600;
}

.cart-item-info span {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.cart-item-price {
    font-weight: 700;
    color: var(--text-dark);
}

.cart-item-remove {
    background: none;
    border: none;
    color: var(--danger);
    cursor: pointer;
    font-size: 0.9rem;
    padding-left: 10px;
}

.cart-summary {
    border-top: 2px solid var(--border-color);
    padding-top: 15px;
    margin-bottom: 20px;
}

.cart-row {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    font-size: 0.95rem;
}

.cart-row-total {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--primary);
    border-top: 1px dashed var(--border-color);
    padding-top: 12px;
    margin-top: 6px;
}

/* ----------------------------------
   8. ULASAN CARD LIST
   ---------------------------------- */
.ulasan-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 25px;
}

.ulasan-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 25px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: var(--transition);
}

.ulasan-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--accent-light);
}

.ulasan-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
}

.ulasan-user h4 {
    font-size: 1rem;
    font-weight: 700;
}

.ulasan-user span {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.ulasan-rating {
    color: #ffb300;
    font-size: 0.95rem;
}

.ulasan-body {
    flex: 1;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--text-dark);
    line-height: 1.5;
    margin-bottom: 20px;
}

.ulasan-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--bg-light);
    padding-top: 12px;
    font-size: 0.8rem;
    color: var(--text-muted);
}

.ulasan-service {
    background-color: var(--bg-light);
    padding: 4px 10px;
    border-radius: 20px;
    font-weight: 500;
    color: var(--primary-light);
}

/* ----------------------------------
   9. ANGGOTA CREDITS (Footer)
   ---------------------------------- */
.footer-credits {
    text-align: center;
    padding: 25px;
    color: var(--text-muted);
    font-size: 0.85rem;
    border-top: 1px solid var(--border-color);
    margin-top: auto;
}

.footer-credits strong {
    color: var(--primary);
}

/* Keyframes */
@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

@keyframes zoomIn {
    from { transform: scale(0.9); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
}

@keyframes shake {
    0%, 100% { transform: translateX(0); }
    20%, 60% { transform: translateX(-6px); }
    40%, 80% { transform: translateX(6px); }
}

/* ----------------------------------
   10. PRINT MEDIA STYLING (@media print)
   ---------------------------------- */
@media print {
    /* Sembunyikan elemen navigasi dan web */
    body {
        background-color: #fff;
        color: #000;
        font-family: 'Inter', sans-serif;
        font-size: 12px;
    }
    
    .sidebar, .top-navbar, .footer-credits, .btn-spa, .btn-actions, .btn-icon, .form-actions, .panel-header form, .filter-box {
        display: none !important;
    }
    
    .main-content {
        margin-left: 0 !important;
        width: 100% !important;
    }
    
    .content-body {
        padding: 0 !important;
    }
    
    .panel {
        border: none !important;
        box-shadow: none !important;
        margin: 0 !important;
    }
    
    .panel-header {
        border-bottom: 2px solid #000 !important;
        padding: 10px 0 !important;
    }
    
    .panel-title {
        font-size: 1.6rem !important;
        color: #000 !important;
        padding-left: 0 !important;
    }
    
    .panel-title::before {
        display: none !important;
    }
    
    .panel-body {
        padding: 20px 0 !important;
    }
    
    /* Nota Struk Kasir Termal */
    .nota-print-body {
        width: 80mm;
        margin: 0 auto;
        padding: 5mm;
        text-align: center;
        background: #fff;
    }
    
    .nota-header h3 {
        font-size: 14px;
        font-weight: 800;
        margin-bottom: 2px;
    }
    
    .nota-divider {
        border-top: 1px dashed #000;
        margin: 10px 0;
    }
    
    .nota-details {
        text-align: left;
        font-size: 11px;
        line-height: 1.4;
    }
    
    .nota-table {
        width: 100%;
        font-size: 11px;
        margin-top: 10px;
    }
    
    .nota-table th {
        border-bottom: 1px dashed #000;
        padding: 4px 0;
    }
    
    .nota-table td {
        padding: 4px 0;
    }
    
    /* Laporan A4 */
    .laporan-print-body {
        width: 100%;
        padding: 20px;
    }
    
    .laporan-header {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 3px double #000;
        padding-bottom: 15px;
    }
    
    .laporan-header h2 {
        font-size: 20px;
        text-transform: uppercase;
        margin-bottom: 5px;
    }
    
    .laporan-header p {
        font-size: 12px;
        color: #444;
    }
    
    .laporan-stats-table {
        width: 100%;
        margin-bottom: 20px;
        border-collapse: collapse;
    }
    
    .laporan-stats-table td {
        padding: 10px;
        border: 1px solid #ccc;
    }
    
    .custom-table th {
        background-color: #f0f0f0 !important;
        color: #000 !important;
        border-bottom: 2px solid #000 !important;
    }
    
    .custom-table td {
        border-bottom: 1px solid #ccc !important;
    }
}

/* ----------------------------------
   11. REVIEW REPLY CUSTOM UI
   ---------------------------------- */
.ulasan-reply-box {
    margin-top: 15px;
    padding: 15px;
    background-color: var(--bg-light);
    border-left: 3px solid var(--accent);
    border-radius: 4px;
    font-size: 0.88rem;
    text-align: left;
}
.ulasan-reply-header {
    display: flex;
    justify-content: space-between;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 6px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.ulasan-reply-body {
    color: var(--text-dark);
    line-height: 1.4;
    font-style: normal !important;
}
.ulasan-reply-btn {
    font-size: 0.8rem;
    padding: 6px 12px;
    background-color: var(--primary-light);
    color: var(--text-light);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: var(--font-heading);
    font-weight: 600;
    transition: var(--transition);
}
.ulasan-reply-btn:hover {
    background-color: var(--primary);
}
.ulasan-reply-form-container {
    margin-top: 15px;
    padding-top: 15px;
    border-top: 1px dashed var(--border-color);
    text-align: left;
}

/* ----------------------------------
   PAGINATION
   ---------------------------------- */
.pagination-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 20px;
    border-top: 1px solid var(--border-color);
    flex-wrap: wrap;
    gap: 10px;
}

.pagination-info {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 500;
}

.pagination-nav {
    display: flex;
    align-items: center;
    gap: 4px;
}

.pagination-btn {
    min-width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
    color: var(--text-dark);
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    transition: var(--transition);
    padding: 0 8px;
}

.pagination-btn:hover:not(.active):not(.disabled) {
    background: var(--bg-light);
    border-color: var(--accent);
    color: var(--accent-hover);
}

.pagination-btn.active {
    background: linear-gradient(135deg, var(--accent), #e2cf9f);
    color: var(--primary-dark);
    border-color: var(--accent);
    font-weight: 700;
    box-shadow: 0 2px 8px rgba(191, 161, 95, 0.25);
}

.pagination-btn.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
}

/* ----------------------------------
   RESERVATION DETAIL REDESIGN
   ---------------------------------- */
.reservation-detail-redesign {
    display: flex;
    flex-direction: column;
    gap: 22px;
    max-width: 1120px;
    margin: 0 auto 42px;
}

.reservation-detail-hero,
.admin-detail-section {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    box-shadow: var(--shadow-soft);
}

.reservation-detail-hero {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 26px;
    align-items: center;
}

.detail-back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--accent-hover);
    font-size: 0.84rem;
    font-weight: 700;
    margin-bottom: 12px;
}

.reservation-detail-hero h2 {
    margin: 0 0 6px;
    color: var(--primary-dark);
    font-size: 1.75rem;
}

.reservation-detail-hero p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.92rem;
}

.detail-hero-status {
    min-width: 180px;
    padding: 14px 16px;
    border-radius: 12px;
    background: var(--bg-light);
    border: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: right;
}

.detail-hero-status strong {
    color: var(--text-dark);
    font-size: 0.95rem;
}

.detail-hero-status span:last-child {
    color: var(--text-muted);
    font-size: 0.85rem;
}

.admin-detail-section {
    padding: 22px 24px;
}

.section-heading-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 16px;
    margin-bottom: 18px;
    border-bottom: 1px solid var(--border-color);
}

.section-kicker {
    display: block;
    margin-bottom: 5px;
    color: var(--accent-hover);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.section-heading-row h3 {
    margin: 0;
    color: var(--primary-dark);
    font-size: 1.18rem;
}

.detail-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 999px;
    background: var(--bg-light);
    border: 1px solid var(--border-color);
    color: var(--primary);
    font-size: 0.82rem;
    font-weight: 700;
    white-space: nowrap;
}

.detail-summary-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
}

.detail-info-item {
    padding: 14px;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: #fffdf9;
    min-height: 76px;
}

.detail-info-item span,
.payment-stat-grid span,
.settlement-summary span {
    display: block;
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 6px;
}

.detail-info-item strong {
    color: var(--text-dark);
    font-size: 0.94rem;
}

.detail-total-item {
    background: #fff7f0;
}

.detail-total-item strong {
    color: var(--accent-hover);
    font-size: 1.12rem;
}

.service-assignment-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.service-assignment-card {
    display: grid;
    grid-template-columns: minmax(240px, 1fr) minmax(360px, 1.25fr);
    gap: 18px;
    align-items: center;
    padding: 16px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: linear-gradient(180deg, #fff, #fffaf4);
}

.service-assignment-info {
    display: flex;
    flex-direction: column;
    gap: 5px;
}

.service-category {
    color: var(--accent-hover);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.service-assignment-info strong {
    color: var(--primary-dark);
    font-size: 1rem;
}

.service-assignment-info small {
    color: var(--text-muted);
    font-weight: 600;
}

.service-assignment-control {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px;
    align-items: center;
}

.payment-detail-layout {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 22px;
}

.payment-proof-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.payment-proof-card > span {
    color: var(--primary);
    font-size: 0.82rem;
    font-weight: 800;
}

.payment-proof-frame {
    width: 100%;
    aspect-ratio: 1 / 1;
    border: 1px dashed var(--accent);
    border-radius: 12px;
    background: #fff8f8;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.payment-proof-frame img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    cursor: pointer;
}

.payment-proof-frame i {
    color: var(--text-muted);
    font-size: 2rem;
}

.payment-info-stack {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.payment-stat-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
}

.payment-stat-grid > div {
    padding: 12px 14px;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: #fffdf9;
}

.payment-stat-grid strong {
    color: var(--text-dark);
    font-size: 0.94rem;
}

.payment-complete-note {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-radius: 10px;
    background: var(--success-bg);
    color: var(--success);
    font-weight: 700;
    font-size: 0.86rem;
}

.detail-verification-form {
    margin-top: 0;
}

.empty-detail-state {
    min-height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 10px;
    color: var(--text-muted);
    border: 1px dashed var(--border-color);
    border-radius: 12px;
    background: var(--bg-light);
}

.empty-detail-state i {
    font-size: 1.7rem;
}

.operational-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
}

.operation-card {
    padding: 16px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: #fffdf9;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.operation-card label {
    color: var(--primary);
    font-size: 0.84rem;
    font-weight: 800;
}

.operation-card .btn-spa {
    justify-content: center;
}

.settlement-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
}

.settlement-summary > div {
    padding: 10px;
    border-radius: 8px;
    background: var(--bg-light);
    border: 1px solid var(--border-color);
}

.settlement-summary strong {
    color: var(--accent-hover);
    font-size: 0.9rem;
}

.cash-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
}

.settlement-done,
.settlement-muted {
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 180px;
}

.settlement-done i {
    color: var(--success);
    font-size: 1.7rem;
}

.settlement-muted i {
    color: var(--text-muted);
    font-size: 1.7rem;
}

.settlement-done p,
.settlement-muted p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.86rem;
}

@media (max-width: 1100px) {
    .detail-summary-grid,
    .payment-stat-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .service-assignment-card,
    .payment-detail-layout,
    .operational-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 720px) {
    .reservation-detail-hero,
    .section-heading-row,
    .service-assignment-control {
        flex-direction: column;
        align-items: stretch;
    }

    .service-assignment-control,
    .detail-summary-grid,
    .payment-stat-grid,
    .settlement-summary,
    .cash-grid {
        grid-template-columns: 1fr;
    }

    .detail-hero-status {
        text-align: left;
        width: 100%;
    }
}

/* ----------------------------------
   12. FIELD HINTS & FORM ACCESSIBILITY
   ---------------------------------- */

/* Asterisk for required fields */
.req-star {
    color: #e05252;
    margin-left: 3px;
    font-size: 0.75em;
    vertical-align: super;
    font-weight: 700;
    line-height: 1;
}

/* Small helper / hint text below input */
.field-hint {
    display: flex;
    align-items: flex-start;
    gap: 5px;
    margin-top: 5px;
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 500;
    line-height: 1.4;
    padding: 0 2px;
    transition: color 0.2s ease;
}

.field-hint i {
    font-size: 0.72rem;
    color: var(--accent-hover);
    margin-top: 2px;
    flex-shrink: 0;
}

/* Highlight hint when the input above is focused */
.form-group:focus-within .field-hint {
    color: var(--accent-hover);
}

.form-group:focus-within .field-hint i {
    color: var(--accent);
}

/* Validation error state for hint */
.field-hint.hint-error {
    color: var(--danger);
}

.field-hint.hint-error i {
    color: var(--danger);
}

/* Subtle "required" badge next to label (optional, use .req-label class) */
.form-group label {
    display: flex;
    align-items: center;
    gap: 0;
}

/* Ensure form-control transitions are smooth on invalid */
.form-control:invalid:not(:placeholder-shown) {
    border-color: rgba(211, 47, 47, 0.45);
}

/* Clean focus ring */
.form-control:focus {
    outline: none;
    border-color: var(--accent);
    background-color: var(--bg-card);
    box-shadow: 0 0 0 3px rgba(211, 150, 115, 0.13), 0 1px 3px rgba(61, 46, 35, 0.06);
}

/* Modal Popup Fade In Animation */
@keyframes popupFadeIn {
    from {
        opacity: 0;
        transform: scale(0.96);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}


